[run]
source = app
omit =
    app/tests/*
    app/log/*
    */migrations/*
    */__pycache__/*
    */site-packages/*
branch = True

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

precision = 2
show_missing = True
fail_under = 0

[html]
directory = htmlcov
show_contexts = True

[xml]
output = coverage.xml

[lcov]
output = lcov.info
